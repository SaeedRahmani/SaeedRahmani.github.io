<canvas
  id="lidar-scene"
  class="w-full h-full object-cover"
  style="opacity: 0; transition: opacity 1.5s ease; display: block;"
></canvas>

<script is:inline>
(function () {
  const canvas = document.getElementById('lidar-scene');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  let W, H, CX, CY;
  let SCALE = 1;
  let RW = 160;
  let dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));

  function resize() {
    let oldCX = CX;
    let oldCY = CY;
    let oldScale = SCALE;
    dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));

    W = canvas.parentElement.clientWidth || window.innerWidth;
    H = canvas.parentElement.clientHeight || window.innerHeight;
    canvas.width = Math.floor(W * dpr);
    canvas.height = Math.floor(H * dpr);
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    CX = W / 2;
    CY = H / 2;
    SCALE = W < 640 ? 0.6 : 1;
    RW = 160 * SCALE;

    if (oldCX !== undefined && cvs && cvs.length > 0) {
      if (oldScale !== SCALE) {
        spawnCrossVehicles();
        if (ego) {
          ego.y = -300 * SCALE;
          ego.state = 'approach';
          ego.spd = 0;
        }
      } else {
        let dx = CX - oldCX;
        let dy = CY - oldCY;
        for (let c of cvs) {
          c.x += dx;
          c.y += dy;
        }
        if (ego) ego.y += dy;
      }
    }

    if (ego && ego.y > H + 100 * SCALE) ego.y = -300 * SCALE;
  }
  
  window.addEventListener('resize', resize);

  const hero  = document.getElementById('hero');
  const ACCENT = (hero ? getComputedStyle(hero).getPropertyValue('--accent-color').trim() : '') || '#1d4ed8';
  
  function hx(h) { 
    h = h.replace('#', '');
    if (h.length === 3) h = h.split('').map(c => c+c).join('');
    return [parseInt(h.slice(0,2),16),parseInt(h.slice(2,4),16),parseInt(h.slice(4,6),16)]; 
  }
  const [ar,ag,ab] = hx(ACCENT);
  const rgba = a => `rgba(${ar},${ag},${ab},${a})`;

  let ego = { x: 0, y: 0, spd: 0, state: 'approach' };
  let cvs = [];

  const mouse = { x: -1000, y: -1000, active: false };

  function setupMouse() {
    const handleMove = e => {
      if (!canvas) return;
      const rect = canvas.getBoundingClientRect();
      let cx = e.clientX;
      let cy = e.clientY;
      if (e.touches && e.touches.length > 0) {
          cx = e.touches[0].clientX;
          cy = e.touches[0].clientY;
      }
      if (cx === undefined || cy === undefined) return;
      const x = cx - rect.left;
      const y = cy - rect.top;
      if (x >= 0 && x <= rect.width && y >= 0 && y <= rect.height) {
          mouse.x = x;
          mouse.y = y;
          mouse.active = true;
      } else {
          mouse.active = false;
      }
    };
    window.addEventListener('mousemove', handleMove, {passive: true});
    window.addEventListener('touchmove', handleMove, {passive: true});
    window.addEventListener('touchstart', handleMove, {passive: true});
    window.addEventListener('touchend', () => { mouse.active = false; });
  }
  setupMouse();

  // Accept ghost cursor position from the demo animation
  window.__lidarMouse = mouse;

  function spawnCrossVehicles() {
    cvs = [
      { x: CX - 600 * SCALE, y: CY + RW/4, len: 44 * SCALE, wid: 20 * SCALE, baseSpd: 3.5 * SCALE, spd: 3.5 * SCALE },
      { x: CX + 400 * SCALE, y: CY - RW/4, len: 44 * SCALE, wid: 20 * SCALE, baseSpd: -2.8 * SCALE, spd: -2.8 * SCALE },
      { x: CX - 100 * SCALE, y: CY + RW/4, len: 44 * SCALE, wid: 20 * SCALE, baseSpd: 3.2 * SCALE, spd: 3.2 * SCALE },
    ];
  }

  const RAYS = 360;
  const hitAlpha = new Float32Array(RAYS);
  const hitPX    = new Float32Array(RAYS);
  const hitPY    = new Float32Array(RAYS);
  const hadHit   = new Uint8Array(RAYS);
  let sweep = 0;
  const SSPD = 0.045;

  function segHit(dx, dy, ax, ay, bx, by, ox, oy) {
    const ex = bx-ax, ey = by-ay;
    const d = dx*ey - dy*ex;
    if (Math.abs(d) < 1e-9) return null;
    const fx = ax-ox, fy = ay-oy;
    const t = (fx*ey - fy*ex) / d;
    const u = (fx*dy - fy*dx) / d;
    return (t > 0.5 && u >= 0 && u <= 1) ? t : null;
  }

  function recast() {
    const MAX_R = Math.min(W, H) * 0.75 + 100;
    const polys = [
      [[-20, -20], [CX-RW/2, -20], [CX-RW/2, CY-RW/2], [-20, CY-RW/2]],
      [[W+20, -20], [CX+RW/2, -20], [CX+RW/2, CY-RW/2], [W+20, CY-RW/2]],
      [[-20, H+20], [CX-RW/2, H+20], [CX-RW/2, CY+RW/2], [-20, CY+RW/2]],
      [[W+20, H+20], [CX+RW/2, H+20], [CX+RW/2, CY+RW/2], [W+20, CY+RW/2]]
    ];

    for (let c of cvs) {
      let hw = c.len/2, hh = c.wid/2;
      polys.push([[c.x-hw, c.y-hh], [c.x+hw, c.y-hh], [c.x+hw, c.y+hh], [c.x-hw, c.y+hh]]);
    }

    for (let i = 0; i < RAYS; i++) {
      const ang = (i / RAYS) * Math.PI * 2;
      const dx = Math.cos(ang), dy = Math.sin(ang);
      let minT = MAX_R, hit = 0;

      for (const poly of polys) {
        const L = poly.length;
        for (let j = 0; j < L; j++) {
          const [ax,ay] = poly[j], [bx,by] = poly[(j+1)%L];
          const t = segHit(dx,dy,ax,ay,bx,by, ego.x, ego.y);
          if (t && t < minT) { minT = t; hit = 1; }
        }
      }

      if (hit) { hitPX[i] = ego.x + dx*minT; hitPY[i] = ego.y + dy*minT; }
      hadHit[i] = hit;
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    ctx.strokeStyle = 'rgba(0,0,0,0.25)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(CX - RW/2, 0); ctx.lineTo(CX - RW/2, CY - RW/2);
    ctx.moveTo(CX - RW/2, CY + RW/2); ctx.lineTo(CX - RW/2, H);
    ctx.moveTo(CX + RW/2, 0); ctx.lineTo(CX + RW/2, CY - RW/2);
    ctx.moveTo(CX + RW/2, CY + RW/2); ctx.lineTo(CX + RW/2, H);
    ctx.stroke();

    ctx.beginPath();
    ctx.moveTo(0, CY - RW/2); ctx.lineTo(CX - RW/2, CY - RW/2);
    ctx.moveTo(CX + RW/2, CY - RW/2); ctx.lineTo(W, CY - RW/2);
    ctx.moveTo(0, CY + RW/2); ctx.lineTo(CX - RW/2, CY + RW/2);
    ctx.moveTo(CX + RW/2, CY + RW/2); ctx.lineTo(W, CY + RW/2);
    ctx.stroke();

    ctx.strokeStyle = 'rgba(0,0,0,0.15)';
    ctx.setLineDash([16, 24]);
    ctx.beginPath();
    ctx.moveTo(CX, 0); ctx.lineTo(CX, CY - RW/2);
    ctx.moveTo(CX, CY + RW/2); ctx.lineTo(CX, H);
    ctx.moveTo(0, CY); ctx.lineTo(CX - RW/2, CY);
    ctx.moveTo(CX + RW/2, CY); ctx.lineTo(W, CY);
    ctx.stroke();
    ctx.setLineDash([]);

    ctx.strokeStyle = 'rgba(0,0,0,0.3)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(CX - RW/2, CY - RW/2 - 25 * SCALE); ctx.lineTo(CX, CY - RW/2 - 25 * SCALE);
    ctx.stroke();

    ctx.lineWidth = 1;
    for (let c of cvs) {
      ctx.beginPath();
      ctx.roundRect(c.x - c.len/2, c.y - c.wid/2, c.len, c.wid, 4 * SCALE);
      ctx.fillStyle = 'rgba(0,0,0,0.06)';
      ctx.fill();
      ctx.strokeStyle = 'rgba(0,0,0,0.4)';
      ctx.stroke();
    }

    ctx.fillStyle = rgba(0.9);
    ctx.shadowColor = rgba(0.6);
    ctx.shadowBlur = 15;
    ctx.beginPath();
    ctx.roundRect(ego.x - 10 * SCALE, ego.y - 18 * SCALE, 20 * SCALE, 36 * SCALE, 4 * SCALE);
    ctx.fill();
    ctx.shadowBlur = 0;

    const MAX_R = Math.min(W, H) * 0.75 + 100;
    const arc = Math.PI / 3.5;
    ctx.save();
    ctx.translate(ego.x, ego.y);
    ctx.rotate(sweep);
    ctx.beginPath();
    ctx.moveTo(0, 0);
    ctx.arc(0, 0, MAX_R, -arc, 0);
    ctx.closePath();
    
    const g = ctx.createRadialGradient(0, 0, 0, 0, 0, MAX_R);
    g.addColorStop(0, rgba(0.12));
    g.addColorStop(0.5, rgba(0.04));
    g.addColorStop(1, rgba(0));
    ctx.fillStyle = g;
    ctx.fill();
    
    ctx.beginPath();
    ctx.moveTo(0,0); ctx.lineTo(MAX_R, 0);
    ctx.strokeStyle = rgba(0.35);
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.restore();

    ctx.fillStyle = rgba(0.85);
    for (let i = 0; i < RAYS; i++) {
      if (hitAlpha[i] < 0.02) continue;
      ctx.globalAlpha = hitAlpha[i];
      ctx.beginPath();
      ctx.arc(hitPX[i], hitPY[i], 1.8, 0, Math.PI*2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }

  function update() {
    const STOP_LINE = CY - RW/2 - 25 * SCALE;
    ego.x = CX - RW/4;
    
    let danger = cvs.some(c => c.x > CX - RW/2 - 80 * SCALE && c.x < CX + RW/2 + 80 * SCALE);

    let egoBlocked = false;
    if (mouse.active) {
        let dy = mouse.y - ego.y;
        let dx = Math.abs(mouse.x - ego.x);
        if (dy > -20 && dy < 250 * SCALE && dx < 80 * SCALE) egoBlocked = true;
    }
    for (let c of cvs) {
        let dx = Math.abs(c.x - ego.x);
        let dy = c.y - ego.y;
        if (dx < (c.len/2 + 25 * SCALE) && dy > 0 && dy < 110 * SCALE) egoBlocked = true;
    }

    if (ego.state === 'approach') {
      let dist = STOP_LINE - ego.y;
      if (dist < 180 * SCALE && dist > 0 && danger) {
        ego.state = 'stopping';
      } else if (dist <= 0) {
        if (danger) { ego.state = 'wait'; ego.spd = 0; }
        else ego.state = 'cross';
      }
      ego.spd += (3.5 * SCALE - ego.spd) * 0.04;
    } else if (ego.state === 'stopping') {
      let dist = STOP_LINE - ego.y;
      let targetSpd = Math.max(dist * 0.05, 0.5 * SCALE);
      if (ego.spd < targetSpd) {
          ego.spd += (targetSpd - ego.spd) * 0.1;
      } else {
          ego.spd = targetSpd;
      }
      if (dist <= 2 * SCALE) { ego.y = STOP_LINE; ego.spd = 0; ego.state = 'wait'; }
    } else if (ego.state === 'wait') {
      ego.spd += (0 - ego.spd) * 0.2;
      if (!danger) ego.state = 'cross';
    } else if (ego.state === 'cross') {
      ego.spd += (4.5 * SCALE - ego.spd) * 0.06;
      if (ego.y > H + 150 * SCALE) {
        ego.y = -300 * SCALE;
        ego.state = 'approach';
        spawnCrossVehicles();
      }
    }
    
    if (egoBlocked) {
        ego.spd += (0 - ego.spd) * 0.2;
    }
    ego.y += ego.spd;

    for (let i = 0; i < cvs.length; i++) {
      let c = cvs[i];
      let blocked = false;
      let dir = c.baseSpd > 0 ? 1 : -1;

      if (mouse.active) {
          let dx = mouse.x - c.x;
          let dy = Math.abs(mouse.y - c.y);
          if (dy < 120 * SCALE) {
              if (dir === 1 && dx > 0 && dx < 250 * SCALE) blocked = true;
              if (dir === -1 && dx < 0 && dx > -250 * SCALE) blocked = true;
          }
      }
      
      for (let j = 0; j < cvs.length; j++) {
          if (i === j) continue;
          let other = cvs[j];
          let otherDir = other.baseSpd > 0 ? 1 : -1;
          if (dir === otherDir) {
              let dx = other.x - c.x;
              if (dir === 1 && dx > 0 && dx < 120 * SCALE) blocked = true;
              if (dir === -1 && dx < 0 && dx > -120 * SCALE) blocked = true;
          }
      }
      
      if (Math.abs(ego.y - c.y) < 60 * SCALE) {
          let ex = ego.x - c.x;
          if (dir === 1 && ex > 0 && ex < (ego.spd > 0.5 ? 120 : 60) * SCALE) blocked = true;
          if (dir === -1 && ex < 0 && ex > -(ego.spd > 0.5 ? 120 : 60) * SCALE) blocked = true;
      }

      let target = blocked ? 0 : c.baseSpd;
      c.spd += (target - c.spd) * 0.1;
      c.x += c.spd;

      if (dir === 1 && c.x > W + 400 * SCALE) c.x = -200 * SCALE;
      if (dir === -1 && c.x < -400 * SCALE) c.x = W + 200 * SCALE;
    }

    const prev = sweep;
    sweep = (sweep + SSPD) % (Math.PI * 2);
    recast();

    for (let i = 0; i < RAYS; i++) {
      const ang = (i/RAYS)*Math.PI*2;
      const fresh = prev < sweep ? (ang>=prev && ang<sweep) : (ang>=prev || ang<sweep);
      hitAlpha[i] = fresh ? (hadHit[i] ? 1.0 : 0) : hitAlpha[i] * 0.96;
    }
  }

  function frame() {
    if (W && H) {
      update();
      draw();
    }
    requestAnimationFrame(frame);
  }

  resize();
  ego.y = -300 * SCALE;
  spawnCrossVehicles();
  frame();
  setTimeout(() => { canvas.style.opacity = '1'; }, 300);
})();
</script>
