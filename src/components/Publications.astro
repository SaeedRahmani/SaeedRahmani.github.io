---
import { siteConfig } from "../config";

// ---------------------------------------------------------------------------
// Strategy: config papers are authoritative (correct title/venue/awards).
// Semantic Scholar adds any additional papers not already in config,
// and enriches all papers with live citation counts.
// Result: complete + accurate + auto-updated list.
// ---------------------------------------------------------------------------
type Pub = {
  title: string;
  year: string;
  authors: string;
  venue: string;
  type: "Journal" | "Conference";
  link?: string;
  award?: string;
  citationCount?: number;
};

const key = (title: string) => title.toLowerCase().replace(/[^a-z0-9]/g, "").slice(0, 40);
// Shorter key for fuzzy dedup (catches slight title variations)
const shortKey = (title: string) => title.toLowerCase().replace(/[^a-z0-9]/g, "").slice(0, 25);

// Start with config papers (authoritative)
const configPubs: Pub[] = (siteConfig.publications ?? []).map((p) => ({
  ...p,
  type: p.type as "Journal" | "Conference",
}));

// Fetch from Semantic Scholar: adds extra papers + citation counts
if (siteConfig.semanticScholarId) {
  try {
    const res = await fetch(
      `https://api.semanticscholar.org/graph/v1/author/${siteConfig.semanticScholarId}/papers` +
        `?fields=title,year,venue,authors,externalIds,citationCount,publicationTypes&limit=100`,
      { signal: AbortSignal.timeout(8000) }
    );
    if (res.ok) {
      const data = (await res.json()) as { data: any[] };

      for (const p of data.data) {
        if (!p.title || !p.year) continue;
        const pKey = key(p.title);

        // Enrich existing config paper with citation count (exact or fuzzy title match)
        const existing = configPubs.find(
          (c) => key(c.title) === pKey || shortKey(c.title) === shortKey(p.title)
        );
        if (existing) {
          if (p.citationCount > 0) existing.citationCount = p.citationCount;
          // Backfill venue from API if config venue is a placeholder
          if (
            !existing.venue ||
            existing.venue.toLowerCase().includes("submitted") ||
            existing.venue.toLowerCase().includes("under review")
          ) {
            if (p.venue && p.venue !== "arXiv.org") existing.venue = p.venue;
          }
          continue;
        }

        // New paper not in config — add it from Semantic Scholar
        const types: string[] = p.publicationTypes ?? [];
        const isJournal = types.some((t: string) => ["JournalArticle", "Review"].includes(t));
        const doi = p.externalIds?.DOI;
        const arxiv = p.externalIds?.ArXiv;

        // Derive a meaningful venue label
        let venueLabel = p.venue ?? "";
        if (!venueLabel || venueLabel === "arXiv.org") {
          venueLabel = arxiv ? "arXiv preprint" : doi ? "Preprint" : "";
        }

        configPubs.push({
          title: p.title,
          year: String(p.year),
          authors: (p.authors as { name: string }[]).map((a) => a.name).join(", "),
          venue: venueLabel,
          type: isJournal ? "Journal" : "Conference",
          link: doi
            ? `https://doi.org/${doi}`
            : arxiv
              ? `https://arxiv.org/abs/${arxiv}`
              : `https://www.semanticscholar.org/paper/${p.paperId}`,
          citationCount: p.citationCount > 0 ? p.citationCount : undefined,
        });
      }
    }
  } catch {
    // best-effort — config papers still show
  }
}

// Sort all by year descending
const pubs = configPubs.sort((a, b) => Number(b.year) - Number(a.year));
const hasPublications = pubs.length > 0;
const PREVIEW = 9;
---

{
  hasPublications && (
    <section id="publications" class="px-6 py-8 lg:px-14 lg:py-10">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 items-start">
          <div class="lg:col-span-3">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Publications
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-9 space-y-3">

            {/* Google Scholar card */}
            <a
              href={siteConfig.social.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between px-4 py-3 rounded-xl border border-gray-200 bg-white hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
            >
              <div class="flex items-center gap-3">
                <div
                  class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                  style={`background-color: ${siteConfig.accentColor}15`}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${siteConfig.accentColor}`}>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-900 group-hover:underline underline-offset-2">
                    View full publication list
                  </p>
                  <p class="text-xs text-gray-400">Google Scholar profile</p>
                </div>
              </div>
              <svg class="w-4 h-4 text-gray-400 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </a>

            {/* Publication list */}
            <div class="border border-gray-200 rounded-xl overflow-hidden divide-y divide-gray-100">
              {pubs.slice(0, PREVIEW).map((pub) => (
                <div class="bg-white flex items-start gap-2 px-4 py-3">
                  <span class="text-xs font-mono text-gray-400 flex-shrink-0 pt-0.5 w-8">
                    {pub.year}
                  </span>
                  <span class="flex-1 min-w-0">
                    <a
                      href={pub.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm font-medium text-gray-900 hover:underline underline-offset-2 leading-snug"
                    >
                      {pub.title}
                    </a>
                    {pub.venue && (
                      <span class="block text-xs text-gray-400 italic mt-0.5">{pub.venue}</span>
                    )}
                  </span>
                  {pub.award && (
                    <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 bg-yellow-50 text-yellow-700 text-xs rounded border border-yellow-200 flex-shrink-0 mt-0.5" title={pub.award}>
                      🏆
                    </span>
                  )}
                </div>
              ))}

              {/* Collapsible extra rows */}
              {pubs.length > PREVIEW && (
                <div id="pub-extras" class="divide-y divide-gray-100 hidden">
                  {pubs.slice(PREVIEW).map((pub) => (
                    <div class="bg-white flex items-start gap-2 px-4 py-3">
                      <span class="text-xs font-mono text-gray-400 flex-shrink-0 pt-0.5 w-8">
                        {pub.year}
                      </span>
                      <span class="flex-1 min-w-0">
                        <a
                          href={pub.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm font-medium text-gray-900 hover:underline underline-offset-2 leading-snug"
                        >
                          {pub.title}
                        </a>
                        {pub.venue && (
                          <span class="block text-xs text-gray-400 italic mt-0.5">{pub.venue}</span>
                        )}
                      </span>
                      {pub.award && (
                        <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 bg-yellow-50 text-yellow-700 text-xs rounded border border-yellow-200 flex-shrink-0 mt-0.5" title={pub.award}>
                          🏆
                        </span>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </div>

            {/* Show more / less toggle button */}
            {pubs.length > PREVIEW && (
              <button
                id="pub-toggle"
                class="w-full flex items-center justify-center gap-1.5 py-2 text-xs font-medium text-gray-500 hover:text-gray-800 border border-gray-200 rounded-lg hover:border-gray-300 transition-colors duration-150 bg-white"
              >
                <span id="pub-toggle-label">Show {pubs.length - PREVIEW} more</span>
                <svg id="pub-toggle-chevron" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            )}

          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  const toggle = document.getElementById("pub-toggle");
  const extras = document.getElementById("pub-extras");
  const label = document.getElementById("pub-toggle-label");
  const chevron = document.getElementById("pub-toggle-chevron");

  if (toggle && extras && label && chevron) {
    const moreCount = extras.children.length;
    toggle.addEventListener("click", () => {
      const isHidden = extras.classList.contains("hidden");
      extras.classList.toggle("hidden", !isHidden);
      label.textContent = isHidden ? "Show less" : `Show ${moreCount} more`;
      chevron.style.transform = isHidden ? "rotate(180deg)" : "";
    });
  }
</script>
