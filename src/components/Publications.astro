---
import { siteConfig } from "../config";
const hasPublications = siteConfig.publications && siteConfig.publications.length > 0;

const journalPubs = siteConfig.publications ? siteConfig.publications.filter(pub => pub.type === 'Journal') : [];
const conferencePubs = siteConfig.publications ? siteConfig.publications.filter(pub => pub.type === 'Conference') : [];
---

{
  hasPublications && (
    <section id="publications" class="p-6 sm:p-8 md:p-10 lg:p-14">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Publications
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            <a
              href={siteConfig.social.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 mt-3 text-xs font-medium hover:underline"
              style={`color: ${siteConfig.accentColor}`}
            >
              Google Scholar
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </a>
          </div>

          <div class="lg:col-span-8 space-y-8">
            {journalPubs.length > 0 && (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
                  Journals
                </h3>
                <div class="divide-y divide-gray-100">
                  {journalPubs.map((pub) => {
                    const Component = pub.link ? "a" : "div";
                    const linkProps = pub.link
                      ? { href: pub.link, target: "_blank", rel: "noopener noreferrer" }
                      : {};
                    return (
                      <div class="py-3 group">
                        <div class="flex items-baseline gap-2 flex-wrap">
                          <span class="text-xs font-mono text-gray-400 flex-shrink-0">
                            {pub.year}
                          </span>
                          <Component
                            {...linkProps}
                            class={`text-sm font-medium text-gray-900 leading-snug ${pub.link ? "group-hover:underline underline-offset-2" : ""}`}
                          >
                            {pub.title}
                          </Component>
                          {pub.award && (
                            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-yellow-50 text-yellow-700 text-xs rounded border border-yellow-200 flex-shrink-0">
                              🏆 {pub.award}
                            </span>
                          )}
                        </div>
                        <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">
                          {pub.authors} · <span class="italic">{pub.venue}</span>
                        </p>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}

            {conferencePubs.length > 0 && (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
                  Conferences
                </h3>
                <div class="divide-y divide-gray-100">
                  {conferencePubs.map((pub) => {
                    const Component = pub.link ? "a" : "div";
                    const linkProps = pub.link
                      ? { href: pub.link, target: "_blank", rel: "noopener noreferrer" }
                      : {};
                    return (
                      <div class="py-3 group">
                        <div class="flex items-baseline gap-2 flex-wrap">
                          <span class="text-xs font-mono text-gray-400 flex-shrink-0">
                            {pub.year}
                          </span>
                          <Component
                            {...linkProps}
                            class={`text-sm font-medium text-gray-900 leading-snug ${pub.link ? "group-hover:underline underline-offset-2" : ""}`}
                          >
                            {pub.title}
                          </Component>
                          {pub.award && (
                            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-yellow-50 text-yellow-700 text-xs rounded border border-yellow-200 flex-shrink-0">
                              🏆 {pub.award}
                            </span>
                          )}
                        </div>
                        <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">
                          {pub.authors} · <span class="italic">{pub.venue}</span>
                        </p>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}
