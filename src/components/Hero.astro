---
import { siteConfig } from "../config";
import BirdsEyeScene from "./BirdsEyeScene.astro";
import PathPlanningGrid from "./PathPlanningGrid.astro";
import LidarScene from "./LidarScene.astro";

// ↓ Change this one word to swap the AV visualization: 'birds-eye' | 'path-planning' | 'lidar'
const activeViz: string = 'lidar';

// ↓ Change this to swap the interactive background: 'network' | 'point-cloud'
const interactiveBg: string = 'network';
---

<div
  id="hero"
  data-bg-type={interactiveBg}
  class="relative isolate overflow-hidden bg-white py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.accentColor}40 0%, ${siteConfig.accentColor}25 20%, ${siteConfig.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  >
  </div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="0787a7c5-978c-4f66-83c7-11c213f99cb7"
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
      <pattern
        id="programming-symbols"
        x="0"
        y="0"
        width="400"
        height="400"
        patternUnits="userSpaceOnUse"
      >
        <text
          x="50"
          y="50"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(-15)">&lt;/&gt;</text
        >
        <text
          x="150"
          y="100"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(10)">{}</text
        >
        <text
          x="250"
          y="80"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-5)">=&gt;</text
        >
        <text
          x="100"
          y="200"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(15)">[]</text
        >
        <text
          x="300"
          y="180"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-10)">&lt;&gt;</text
        >
        <text
          x="200"
          y="250"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(5)">()</text
        >
        <text
          x="50"
          y="320"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-8)">::</text
        >
        <text
          x="350"
          y="300"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(12)">==</text
        >
        <text
          x="150"
          y="350"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-15)">++</text
        >
        <text
          x="250"
          y="370"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(8)">;</text
        >
      </pattern>
    </defs>
    <rect
      fill="url(#programming-symbols)"
      width="100%"
      height="100%"
      opacity="0.2"></rect>
    <rect
      fill="url(#0787a7c5-978c-4f66-83c7-11c213f99cb7)"
      width="100%"
      height="100%"
      stroke-width={0}></rect>
  </svg>

  <!-- AV Visualization — Fullscreen background -->
  <div class="absolute inset-0 -z-[5] flex items-center justify-center pointer-events-none overflow-hidden" aria-hidden="true" style="opacity: 0.35; filter: saturate(0.5);">
    {activeViz === 'birds-eye' ? <BirdsEyeScene /> : activeViz === 'lidar' ? <LidarScene /> : <PathPlanningGrid />}
  </div>

  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center relative z-10">
    <div class="w-full max-w-2xl">
        <h2
          class="text-pretty text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-700 animate-fade-in"
        >
          Hello! 👋
        </h2>
        <h1
          class="mt-6 sm:mt-8 md:mt-10 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
        >
          This is <span style={{ color: siteConfig.accentColor }}
            >Saeed</span
          >
        </h1>
        <p
          class="mt-4 sm:mt-6 md:mt-8 text-pretty text-base sm:text-lg md:text-xl/8 font-medium text-gray-600 animate-fade-in animation-delay-400"
        >
          {siteConfig.title}
        </p>
    </div>
  </div>
  <div
    class="absolute z-20 bottom-0 left-0 right-0 p-8 sm:p-12 md:p-24 flex gap-x-4 sm:gap-x-6 md:gap-x-8 text-gray-700 animate-fade-in animation-delay-600"
  >
    {
      siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M8 11v5" />
              <path d="M8 8v.01" />
              <path d="M12 16v-5" />
              <path d="M16 16v-3a2 2 0 1 0 -4 0" />
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
            </>
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.twitter && (
        <a
          href={siteConfig.social.twitter}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Google Scholar"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M10 6h-6a1 1 0 0 0 -1 1v11a1 1 0 0 0 1 1h11a1 1 0 0 0 1 -1v-6" />
              <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M16 4l3.5 3.5" />
            </>
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </>
          </svg>
        </a>
      )
    }
  </div>
  <!-- Full-hero animated network background -->
  <div class="absolute inset-0 pointer-events-none" style="z-index: -5;">
    <canvas id="hero-net" class="w-full h-full"></canvas>
  </div>
  <!-- Modern scroll indicator -->
  <div id="scroll-indicator" class="scroll-indicator-container">
    <div class="mouse-shape">
      <div class="mouse-dot"></div>
    </div>
    <span class="scroll-text">scroll</span>
  </div>
</div>

<script is:inline>
  (function () {
    const hero = document.getElementById('hero');
    const indicator = document.getElementById('scroll-indicator');

    indicator.addEventListener('click', () => {
      const next = hero.nextElementSibling;
      if (next) next.scrollIntoView({ behavior: "smooth" });
      else window.scrollBy({ top: window.innerHeight, behavior: "smooth" });
    });
  })();
</script>


<script is:inline>
  (function () {
    const hero = document.getElementById('hero');
    const canvas = document.getElementById('hero-net');
    if (!hero || !canvas) return;

    const ctx = canvas.getContext('2d'); if (!ctx) return;
    const bgType = hero.dataset.bgType || 'point-cloud';

    // Accent color -> rgb
    const accent = getComputedStyle(hero).getPropertyValue('--accent-color').trim();
    const { r, g, b } = (function hexToRgb(hex) {
      const m = hex.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
      if (!m) return { r: 29, g: 78, b: 216 };
      return { r: parseInt(m[1], 16), g: parseInt(m[2], 16), b: parseInt(m[3], 16) };
    })(accent);

    let dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
    let vw = 0, vh = 0;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let running = true;
    document.addEventListener('visibilitychange', () => { running = document.visibilityState === 'visible'; });

    const mouse = { x: -9999, y: -9999, inside: false };
    hero.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      mouse.inside = true;
    }, { passive: true });
    hero.addEventListener('mouseleave', () => {
      mouse.inside = false;
      mouse.x = -9999;
      mouse.y = -9999;
    });

    if (bgType === 'network') {
      let nodes = [];
      let maxDist = 0;
      let nodeCount = 0;
      
      const repelRadius = () => Math.max(90, Math.min(220, Math.sqrt(vw * vh) / 5.5));
      const repelStrength = 0.65;
      const swirlStrength = 0.12;

      function configure() {
        const target = Math.floor((vw * vh) / 16000);
        nodeCount = Math.max(60, Math.min(240, target));
        maxDist = Math.max(80, Math.min(220, Math.sqrt(vw * vh) / 6));
        if (nodes.length > nodeCount) nodes.length = nodeCount;
        else while (nodes.length < nodeCount) nodes.push(makeNode());
      }
      function rand(min, max) { return min + Math.random() * (max - min); }
      function makeNode() {
        const speed = rand(0.2, 0.6);
        const angle = rand(0, Math.PI * 2);
        return {
          x: rand(0, vw), y: rand(0, vh),
          vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
          drift: rand(0.001, 0.004), phase: rand(0, 1000),
          size: rand(1.2, 2.2)
        };
      }
      function resize() {
        const rect = hero.getBoundingClientRect();
        vw = Math.max(1, Math.floor(rect.width));
        vh = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(vw * dpr);
        canvas.height = Math.floor(vh * dpr);
        canvas.style.width = vw + 'px';
        canvas.style.height = vh + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        configure();
      }
      function updateNode(n) {
        n.phase += n.drift;
        n.x += n.vx + Math.cos(n.phase) * 0.15;
        n.y += n.vy + Math.sin(n.phase * 0.9) * 0.15;

        // Mouse repelling for network
        if (mouse.inside) {
          const dx = n.x - mouse.x;
          const dy = n.y - mouse.y;
          const d = Math.hypot(dx, dy) || 1;
          const R = repelRadius();
          if (d < R) {
            const t = 1 - d / R;
            const push = repelStrength * (t * t + 0.05);
            n.x += (dx / d) * push * 6.0;
            n.y += (dy / d) * push * 6.0;
            const tx = -dy / d, ty = dx / d;
            n.x += tx * swirlStrength * t * 8.0;
            n.y += ty * swirlStrength * t * 8.0;
          }
        }

        if (n.x < -10) n.x = vw + 10;
        if (n.x > vw + 10) n.x = -10;
        if (n.y < -10) n.y = vh + 10;
        if (n.y > vh + 10) n.y = -10;
      }
      function drawFrame() {
        if (!running || prefersReduced) return;
        ctx.clearRect(0, 0, vw, vh);

        for (let i = 0; i < nodes.length; i++) updateNode(nodes[i]);

        for (let i = 0; i < nodes.length; i++) {
          const a = nodes[i];
          for (let j = i + 1; j < nodes.length; j++) {
            const b = nodes[j];
            const dx = a.x - b.x, dy = a.y - b.y;
            const dist = Math.hypot(dx, dy);
            if (dist < maxDist) {
              const t = 1 - dist / maxDist;
              ctx.globalAlpha = 0.08 * t;
              ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, 1)`;
              ctx.lineWidth = 1;
              ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
            }
          }
        }
        for (let i = 0; i < nodes.length; i++) {
          const n = nodes[i];
          ctx.globalAlpha = 0.9;
          ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.9)`;
          ctx.beginPath(); ctx.arc(n.x, n.y, n.size, 0, Math.PI * 2); ctx.fill();
        }

        // Erase intersection
        ctx.globalCompositeOperation = 'destination-out';
        ctx.fillStyle = 'rgba(0,0,0,1)';
        ctx.beginPath();
        const CX = vw / 2;
        const CY = vh / 2;
        const SCALE = vw < 640 ? 0.6 : 1;
        const RW = 162 * SCALE; 
        ctx.rect(CX - RW/2, 0, RW, vh);
        ctx.rect(0, CY - RW/2, vw, RW);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-over';

        requestAnimationFrame(drawFrame);
      }
      resize();
      if (!prefersReduced) requestAnimationFrame(drawFrame);
      window.addEventListener('resize', () => {
        dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
        resize();
      }, { passive: true });

    } else {
      // Point Cloud
      let dots = [];
      const GRID_SIZE = 35;
      const interactionRadius = 160;
      const forceFactor = 2.0;

      function resize() {
        const rect = hero.getBoundingClientRect();
        vw = Math.max(1, Math.floor(rect.width));
        vh = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(vw * dpr);
        canvas.height = Math.floor(vh * dpr);
        canvas.style.width = vw + 'px';
        canvas.style.height = vh + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        initDots();
      }
      function initDots() {
        dots = [];
        const cols = Math.ceil(vw / GRID_SIZE) + 1;
        const rows = Math.ceil(vh / GRID_SIZE) + 1;
        for (let i = 0; i < cols; i++) {
          for (let j = 0; j < rows; j++) {
            const baseX = i * GRID_SIZE;
            const baseY = j * GRID_SIZE;
            dots.push({
              baseX: baseX, baseY: baseY,
              x: baseX, y: baseY,
              vx: 0, vy: 0,
              baseRadius: 1.2,
            });
          }
        }
      }
      function updateDot(d) {
        if (mouse.inside) {
          const dx = d.x - mouse.x;
          const dy = d.y - mouse.y;
          const dist = Math.hypot(dx, dy);
          if (dist < interactionRadius && dist > 0.1) {
            const force = (interactionRadius - dist) / interactionRadius;
            d.vx += (dx / dist) * force * forceFactor;
            d.vy += (dy / dist) * force * forceFactor;
          }
        }
        const springK = 0.08, friction = 0.82;
        d.vx += (d.baseX - d.x) * springK;
        d.vy += (d.baseY - d.y) * springK;
        d.vx *= friction;
        d.vy *= friction;
        d.x += d.vx;
        d.y += d.vy;
      }
      function drawFrame() {
        if (!running || prefersReduced) return;
        ctx.clearRect(0, 0, vw, vh);

        for (let i = 0; i < dots.length; i++) {
          const d = dots[i];
          updateDot(d);
          const distHome = Math.hypot(d.x - d.baseX, d.y - d.baseY);
          const stretchRatio = Math.min(1, distHome / 20);
          const radius = d.baseRadius + stretchRatio * 2.0;
          const maxOpacity = 0.15;
          const stretchOpacity = 0.7;
          const alpha = Math.min(1.0, maxOpacity + stretchRatio * stretchOpacity);

          ctx.beginPath();
          ctx.arc(d.x, d.y, radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
          ctx.fill();
          
          if(stretchRatio > 0.05) {
            ctx.beginPath();
            ctx.moveTo(d.baseX, d.baseY);
            ctx.lineTo(d.x, d.y);
            ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${alpha * 0.4})`;
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        }

        ctx.globalCompositeOperation = 'destination-out';
        ctx.fillStyle = 'rgba(0,0,0,1)';
        ctx.beginPath();
        const CX = vw / 2;
        const CY = vh / 2;
        const SCALE = vw < 640 ? 0.6 : 1;
        const RW = 162 * SCALE; 
        ctx.rect(CX - RW/2, 0, RW, vh);
        ctx.rect(0, CY - RW/2, vw, RW);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-over';

        requestAnimationFrame(drawFrame);
      }
      resize();
      if (!prefersReduced) requestAnimationFrame(drawFrame);
      window.addEventListener('resize', () => {
        dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
        resize();
      }, { passive: true });
    }
  })();
</script>
<style>

  #hero-net {
  opacity: 0;
  animation: fadeIn 1s ease-out 0.2s forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }
  /* Container positioning */
  .scroll-indicator-container {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    cursor: pointer;
    text-align: center;
    pointer-events: auto;
    opacity: 0.6;
    transition: opacity .3s ease;
    z-index: 10;
  }

  /* Responsive positioning to match social icons */
  @media (min-width: 640px) {
    .scroll-indicator-container {
      bottom: 3rem;
      right: 3rem;
    }
  }

  @media (min-width: 768px) {
    .scroll-indicator-container {
      bottom: 6rem;
      right: 6rem;
    }
  }

  /* Mouse outline */
  .mouse-shape {
    width: 34px;
    height: 58px;
    border: 2px solid rgba(60, 60, 60, 0.6);
    border-radius: 22px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
    margin: 0 auto;
    backdrop-filter: blur(2px);
  }

  /* Moving dot */
  .mouse-dot {
    width: 6px;
    height: 6px;
    background: rgba(40, 40, 40, 0.8);
    border-radius: 50%;
    margin-top: 6px;
    animation: mouse-scroll 1.4s ease-in-out infinite;
  }

  /* scroll text */
  .scroll-text {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-top: .45rem;
    color: rgba(50, 50, 50, 0.7);
    font-weight: 500;
  }

  /* Hover effect */
  .scroll-indicator-container:hover {
    opacity: 1;
  }

  /* Dot animation */
  @keyframes mouse-scroll {
    0% { transform: translateY(18px); opacity: 0; }
    40% { opacity: 1; }
    100% { transform: translateY(0px); opacity: 1; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .mouse-dot { animation: none; opacity: 0.8; }
  }


</style>
