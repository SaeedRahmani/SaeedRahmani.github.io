---
import { siteConfig } from "../config";
import BirdsEyeScene from "./BirdsEyeScene.astro";
import PathPlanningGrid from "./PathPlanningGrid.astro";
import LidarScene from "./LidarScene.astro";

// ↓ Change this one word to swap the AV visualization: 'birds-eye' | 'path-planning' | 'lidar'
const activeViz: string = 'lidar';

// ↓ Change this to swap the interactive background: 'network' | 'point-cloud'
const interactiveBg: string = 'network';

// ↓ Change this to swap the interaction hint: 'none' | 'tooltip' | 'ghost-cursor' | 'both'
const hintMode: string = 'tooltip';
---

<div
  id="hero"
  data-bg-type={interactiveBg}
  data-hint-mode={hintMode}
  class="relative isolate overflow-hidden bg-white py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.accentColor}40 0%, ${siteConfig.accentColor}25 20%, ${siteConfig.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  >
  </div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="0787a7c5-978c-4f66-83c7-11c213f99cb7"
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
      <pattern
        id="programming-symbols"
        x="0"
        y="0"
        width="400"
        height="400"
        patternUnits="userSpaceOnUse"
      >
        <text
          x="50"
          y="50"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(-15)">&lt;/&gt;</text
        >
        <text
          x="150"
          y="100"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(10)">{}</text
        >
        <text
          x="250"
          y="80"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-5)">=&gt;</text
        >
        <text
          x="100"
          y="200"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(15)">[]</text
        >
        <text
          x="300"
          y="180"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-10)">&lt;&gt;</text
        >
        <text
          x="200"
          y="250"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(5)">()</text
        >
        <text
          x="50"
          y="320"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-8)">::</text
        >
        <text
          x="350"
          y="300"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(12)">==</text
        >
        <text
          x="150"
          y="350"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-15)">++</text
        >
        <text
          x="250"
          y="370"
          fill={siteConfig.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(8)">;</text
        >
      </pattern>
    </defs>
    <rect
      fill="url(#programming-symbols)"
      width="100%"
      height="100%"
      opacity="0.2"></rect>
    <rect
      fill="url(#0787a7c5-978c-4f66-83c7-11c213f99cb7)"
      width="100%"
      height="100%"
      stroke-width={0}></rect>
  </svg>

  <!-- AV Visualization — Fullscreen background -->
  <div class="absolute inset-0 -z-[5] flex items-center justify-center pointer-events-none overflow-hidden" aria-hidden="true" style="opacity: 0.35; filter: saturate(0.5);">
    {activeViz === 'birds-eye' ? <BirdsEyeScene /> : activeViz === 'lidar' ? <LidarScene /> : <PathPlanningGrid />}
  </div>

  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center relative z-10">
    <div class="w-full max-w-2xl">
        <h2
          class="text-pretty text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-700 animate-fade-in"
        >
          Hello! 👋
        </h2>
        <h1
          class="mt-6 sm:mt-8 md:mt-10 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
        >
          This is <span style={{ color: siteConfig.accentColor }}
            >Saeed</span
          >
        </h1>
        <p
          class="mt-4 sm:mt-6 md:mt-8 text-pretty text-base sm:text-lg md:text-xl/8 font-medium text-gray-600 animate-fade-in animation-delay-400"
        >
          {siteConfig.title}
        </p>
    </div>
  </div>
  <div
    class="absolute z-20 bottom-0 left-0 right-0 p-8 sm:p-12 md:p-24 flex gap-x-4 sm:gap-x-6 md:gap-x-8 text-gray-700 animate-fade-in animation-delay-600"
  >
    {
      siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M8 11v5" />
              <path d="M8 8v.01" />
              <path d="M12 16v-5" />
              <path d="M16 16v-3a2 2 0 1 0 -4 0" />
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
            </>
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.twitter && (
        <a
          href={siteConfig.social.twitter}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Google Scholar"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M10 6h-6a1 1 0 0 0 -1 1v11a1 1 0 0 0 1 1h11a1 1 0 0 0 1 -1v-6" />
              <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
              <path d="M16 4l3.5 3.5" />
            </>
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </>
          </svg>
        </a>
      )
    }
  </div>
  <!-- Full-hero animated network background -->
  <div class="absolute inset-0 pointer-events-none" style="z-index: -5;">
    <canvas id="hero-net" class="w-full h-full"></canvas>
  </div>
  <!-- Interaction hint tooltip (desktop only) -->
  <div id="interaction-hint" class="interaction-hint hidden md:flex" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hint-icon">
      <path d="M5 3 3.13 5.27a3.5 3.5 0 0 0 0 4.46L5 12" />
      <path d="m19 3 1.87 2.27a3.5 3.5 0 0 1 0 4.46L19 12" />
      <path d="M12 12v6" />
      <path d="M12 21a1 1 0 0 1-1-1v-2a3 3 0 0 1 3-3h0" />
      <path d="M8 2h8" />
      <path d="M12 2v4" />
    </svg>
    <span>Move your cursor to interact with the traffic simulation</span>
  </div>

  <!-- Ghost cursor demo overlay (desktop only) -->
  <canvas id="ghost-cursor-canvas" class="ghost-cursor-canvas" aria-hidden="true"></canvas>

  <!-- Modern scroll indicator -->
  <div id="scroll-indicator" class="scroll-indicator-container">
    <div class="mouse-shape">
      <div class="mouse-dot"></div>
    </div>
    <span class="scroll-text">scroll</span>
  </div>
</div>

<script is:inline>
  (function () {
    const hero = document.getElementById('hero');
    const indicator = document.getElementById('scroll-indicator');

    indicator.addEventListener('click', () => {
      const next = hero.nextElementSibling;
      if (next) next.scrollIntoView({ behavior: "smooth" });
      else window.scrollBy({ top: window.innerHeight, behavior: "smooth" });
    });
  })();
</script>

<script is:inline>
  (function () {
    const hero = document.getElementById('hero');
    const hint = document.getElementById('interaction-hint');
    if (!hero || !hint || window.innerWidth < 768) return;

    var mode = hero.dataset.hintMode || 'tooltip';
    if (mode !== 'tooltip' && mode !== 'both') return;

    let shown = false;
    let hideTimer = null;

    function showHint() {
      if (shown) return;
      shown = true;
      hero.removeEventListener('mouseenter', showHint);

      hint.classList.add('hint-visible');

      hideTimer = setTimeout(function () {
        hint.classList.add('hint-fading');
        hint.addEventListener('animationend', function () {
          hint.classList.remove('hint-visible', 'hint-fading');
        }, { once: true });
      }, 5000);
    }

    function dismissHint() {
      if (!hint.classList.contains('hint-visible')) return;
      if (hideTimer) clearTimeout(hideTimer);
      hint.classList.add('hint-fading');
      hint.addEventListener('animationend', function () {
        hint.classList.remove('hint-visible', 'hint-fading');
      }, { once: true });
    }

    // Show on first mouse enter into hero
    hero.addEventListener('mouseenter', showHint);
    // Dismiss early on click
    hint.addEventListener('click', dismissHint);
  })();
</script>

<script is:inline>
  (function () {
    var hero = document.getElementById('hero');
    var gc = document.getElementById('ghost-cursor-canvas');
    if (!hero || !gc || window.innerWidth < 768) return;

    var mode = hero.dataset.hintMode || 'tooltip';
    if (mode !== 'ghost-cursor' && mode !== 'both') return;

    var ctx = gc.getContext('2d');
    if (!ctx) return;

    var vw, vh;
    function resize() {
      vw = hero.clientWidth;
      vh = hero.clientHeight;
      gc.width = vw;
      gc.height = vh;
      gc.style.width = vw + 'px';
      gc.style.height = vh + 'px';
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    var accent = getComputedStyle(hero).getPropertyValue('--accent-color').trim() || '#1d4ed8';
    function hexRgb(h) {
      h = h.replace('#','');
      return [parseInt(h.slice(0,2),16), parseInt(h.slice(2,4),16), parseInt(h.slice(4,6),16)];
    }
    var rgb = hexRgb(accent);

    // Phases: fadeIn -> circle -> pause -> exit -> done
    // All durations in ms
    var FADE_IN   = 800;
    var CIRCLE    = 4000;   // gentle loop around center
    var PAUSE     = 1200;   // hold still
    var EXIT      = 1500;   // drift away and fade
    var TOTAL     = FADE_IN + CIRCLE + PAUSE + EXIT;

    var startTime = 0;
    var done = false;
    var realMouseMoved = false;
    var cursorX = 0, cursorY = 0, alpha = 0;
    var ripples = [];

    hero.addEventListener('mousemove', function onReal() {
      if (!done) realMouseMoved = true;
      hero.removeEventListener('mousemove', onReal);
    });

    function getCenter() {
      var cx = vw / 2;
      var cy = vh / 2;
      var sc = vw < 640 ? 0.6 : 1;
      var rw = 160 * sc;
      return { cx: cx, cy: cy, rw: rw, sc: sc };
    }

    function drawCursor(x, y, a) {
      ctx.save();
      ctx.globalAlpha = a;
      ctx.translate(x, y);
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(0, 19);
      ctx.lineTo(4.5, 15);
      ctx.lineTo(8, 22);
      ctx.lineTo(11, 20.5);
      ctx.lineTo(7.5, 14);
      ctx.lineTo(13, 14);
      ctx.closePath();
      ctx.fillStyle = 'rgba(' + rgb[0] + ',' + rgb[1] + ',' + rgb[2] + ',' + (0.7 * a) + ')';
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,' + (0.9 * a) + ')';
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.restore();
    }

    function drawRipple(x, y, a, r) {
      ctx.save();
      ctx.globalAlpha = a * 0.3;
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(' + rgb[0] + ',' + rgb[1] + ',' + rgb[2] + ',1)';
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.restore();
    }

    // Easing
    function easeInOutSine(t) { return -(Math.cos(Math.PI * t) - 1) / 2; }
    function easeInQuad(t) { return t * t; }

    var lastRippleTime = 0;

    function animate(ts) {
      if (done) return;
      if (!startTime) startTime = ts;
      var elapsed = ts - startTime;

      ctx.clearRect(0, 0, vw, vh);

      // Abort on real mouse
      if (realMouseMoved) {
        alpha -= 0.04;
        if (alpha <= 0) {
          done = true;
          gc.style.opacity = '0';
          if (window.__lidarMouse) {
            window.__lidarMouse.active = false;
            window.__lidarMouse.x = -1000;
            window.__lidarMouse.y = -1000;
          }
          return;
        }
        drawCursor(cursorX, cursorY, alpha);
        requestAnimationFrame(animate);
        return;
      }

      var c = getCenter();
      var radius = c.rw * 0.45;  // orbit radius around center

      if (elapsed < FADE_IN) {
        // Phase 1: Fade in while starting the circle
        var t = elapsed / FADE_IN;
        alpha = easeInOutSine(t);
        var angle = (t * 0.4) * Math.PI * 2;  // partial circle during fade in
        cursorX = c.cx + Math.cos(angle - Math.PI / 2) * radius * t;
        cursorY = c.cy + Math.sin(angle - Math.PI / 2) * radius * t;

      } else if (elapsed < FADE_IN + CIRCLE) {
        // Phase 2: Gentle orbit around center
        alpha = 1;
        var ct = (elapsed - FADE_IN) / CIRCLE;
        var angle = (0.4 + ct * 1.1) * Math.PI * 2;  // ~1.1 full loops
        // Slowly vary the radius for an organic feel
        var r = radius * (0.85 + 0.15 * Math.sin(ct * Math.PI * 3));
        cursorX = c.cx + Math.cos(angle - Math.PI / 2) * r;
        cursorY = c.cy + Math.sin(angle - Math.PI / 2) * r;

        // Spawn a ripple every ~1200ms
        if (elapsed - lastRippleTime > 1200) {
          ripples.push({ x: cursorX, y: cursorY, r: 4, a: 0.7 });
          lastRippleTime = elapsed;
        }

      } else if (elapsed < FADE_IN + CIRCLE + PAUSE) {
        // Phase 3: Hold still
        alpha = 1;
        // cursorX/cursorY stay at last position

      } else if (elapsed < TOTAL) {
        // Phase 4: Drift upward-right and fade out
        var et = (elapsed - FADE_IN - CIRCLE - PAUSE) / EXIT;
        alpha = 1 - easeInQuad(et);
        cursorX += 0.6;
        cursorY -= 0.4;

      } else {
        // Done
        done = true;
        gc.style.opacity = '0';
        if (window.__lidarMouse) {
          window.__lidarMouse.active = false;
          window.__lidarMouse.x = -1000;
          window.__lidarMouse.y = -1000;
        }
        return;
      }

      // Feed position to LidarScene
      if (alpha > 0.1 && elapsed < FADE_IN + CIRCLE + PAUSE) {
        if (window.__lidarMouse) {
          window.__lidarMouse.x = cursorX;
          window.__lidarMouse.y = cursorY;
          window.__lidarMouse.active = true;
        }
      } else if (elapsed >= FADE_IN + CIRCLE + PAUSE) {
        if (window.__lidarMouse) {
          window.__lidarMouse.active = false;
          window.__lidarMouse.x = -1000;
          window.__lidarMouse.y = -1000;
        }
      }

      // Draw ripples
      for (var ri = ripples.length - 1; ri >= 0; ri--) {
        var rp = ripples[ri];
        rp.r += 0.4;
        rp.a -= 0.008;
        if (rp.a <= 0) { ripples.splice(ri, 1); continue; }
        drawRipple(rp.x, rp.y, rp.a * alpha, rp.r);
      }

      // Draw cursor
      drawCursor(cursorX, cursorY, alpha);

      // Label during circle + pause phase
      if (elapsed > FADE_IN + 800 && elapsed < FADE_IN + CIRCLE + PAUSE) {
        var la = Math.min(1, (elapsed - FADE_IN - 800) / 600) * alpha;
        ctx.save();
        ctx.globalAlpha = la * 0.75;
        ctx.font = '500 13px system-ui, -apple-system, sans-serif';
        ctx.fillStyle = 'rgba(55, 65, 81, 0.9)';
        ctx.fillText('try moving your cursor here', cursorX + 18, cursorY - 8);
        ctx.restore();
      }

      requestAnimationFrame(animate);
    }

    // Start after 1.5s (page fade-in animations finish)
    setTimeout(function () {
      if (done) return;
      gc.style.opacity = '1';
      requestAnimationFrame(animate);
    }, 1500);
  })();
</script>


<script is:inline>
  (function () {
    const hero = document.getElementById('hero');
    const canvas = document.getElementById('hero-net');
    if (!hero || !canvas) return;

    const ctx = canvas.getContext('2d'); if (!ctx) return;
    const bgType = hero.dataset.bgType || 'point-cloud';

    // Accent color -> rgb
    const accent = getComputedStyle(hero).getPropertyValue('--accent-color').trim();
    const { r, g, b } = (function hexToRgb(hex) {
      const m = hex.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
      if (!m) return { r: 29, g: 78, b: 216 };
      return { r: parseInt(m[1], 16), g: parseInt(m[2], 16), b: parseInt(m[3], 16) };
    })(accent);

    let dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
    let vw = 0, vh = 0;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let running = true;
    document.addEventListener('visibilitychange', () => { running = document.visibilityState === 'visible'; });

    const mouse = { x: -9999, y: -9999, inside: false };
    hero.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      mouse.inside = true;
    }, { passive: true });
    hero.addEventListener('mouseleave', () => {
      mouse.inside = false;
      mouse.x = -9999;
      mouse.y = -9999;
    });

    if (bgType === 'network') {
      let nodes = [];
      let maxDist = 0;
      let nodeCount = 0;
      
      const repelRadius = () => Math.max(90, Math.min(220, Math.sqrt(vw * vh) / 5.5));
      const repelStrength = 0.65;
      const swirlStrength = 0.12;

      function configure() {
        const target = Math.floor((vw * vh) / 16000);
        nodeCount = Math.max(60, Math.min(240, target));
        maxDist = Math.max(80, Math.min(220, Math.sqrt(vw * vh) / 6));
        if (nodes.length > nodeCount) nodes.length = nodeCount;
        else while (nodes.length < nodeCount) nodes.push(makeNode());
      }
      function rand(min, max) { return min + Math.random() * (max - min); }
      function makeNode() {
        const speed = rand(0.2, 0.6);
        const angle = rand(0, Math.PI * 2);
        return {
          x: rand(0, vw), y: rand(0, vh),
          vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
          drift: rand(0.001, 0.004), phase: rand(0, 1000),
          size: rand(1.2, 2.2)
        };
      }
      function resize() {
        const rect = hero.getBoundingClientRect();
        vw = Math.max(1, Math.floor(rect.width));
        vh = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(vw * dpr);
        canvas.height = Math.floor(vh * dpr);
        canvas.style.width = vw + 'px';
        canvas.style.height = vh + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        configure();
      }
      function updateNode(n) {
        n.phase += n.drift;
        n.x += n.vx + Math.cos(n.phase) * 0.15;
        n.y += n.vy + Math.sin(n.phase * 0.9) * 0.15;

        // Mouse repelling for network
        if (mouse.inside) {
          const dx = n.x - mouse.x;
          const dy = n.y - mouse.y;
          const d = Math.hypot(dx, dy) || 1;
          const R = repelRadius();
          if (d < R) {
            const t = 1 - d / R;
            const push = repelStrength * (t * t + 0.05);
            n.x += (dx / d) * push * 6.0;
            n.y += (dy / d) * push * 6.0;
            const tx = -dy / d, ty = dx / d;
            n.x += tx * swirlStrength * t * 8.0;
            n.y += ty * swirlStrength * t * 8.0;
          }
        }

        if (n.x < -10) n.x = vw + 10;
        if (n.x > vw + 10) n.x = -10;
        if (n.y < -10) n.y = vh + 10;
        if (n.y > vh + 10) n.y = -10;
      }
      function drawFrame() {
        if (!running || prefersReduced) return;
        ctx.clearRect(0, 0, vw, vh);

        for (let i = 0; i < nodes.length; i++) updateNode(nodes[i]);

        for (let i = 0; i < nodes.length; i++) {
          const a = nodes[i];
          for (let j = i + 1; j < nodes.length; j++) {
            const b = nodes[j];
            const dx = a.x - b.x, dy = a.y - b.y;
            const dist = Math.hypot(dx, dy);
            if (dist < maxDist) {
              const t = 1 - dist / maxDist;
              ctx.globalAlpha = 0.08 * t;
              ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, 1)`;
              ctx.lineWidth = 1;
              ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
            }
          }
        }
        for (let i = 0; i < nodes.length; i++) {
          const n = nodes[i];
          ctx.globalAlpha = 0.9;
          ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.9)`;
          ctx.beginPath(); ctx.arc(n.x, n.y, n.size, 0, Math.PI * 2); ctx.fill();
        }

        // Erase intersection
        ctx.globalCompositeOperation = 'destination-out';
        ctx.fillStyle = 'rgba(0,0,0,1)';
        ctx.beginPath();
        const CX = vw / 2;
        const CY = vh / 2;
        const SCALE = vw < 640 ? 0.6 : 1;
        const RW = 162 * SCALE; 
        ctx.rect(CX - RW/2, 0, RW, vh);
        ctx.rect(0, CY - RW/2, vw, RW);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-over';

        requestAnimationFrame(drawFrame);
      }
      resize();
      if (!prefersReduced) requestAnimationFrame(drawFrame);
      window.addEventListener('resize', () => {
        dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
        resize();
      }, { passive: true });

    } else {
      // Point Cloud
      let dots = [];
      const GRID_SIZE = 35;
      const interactionRadius = 160;
      const forceFactor = 2.0;

      function resize() {
        const rect = hero.getBoundingClientRect();
        vw = Math.max(1, Math.floor(rect.width));
        vh = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(vw * dpr);
        canvas.height = Math.floor(vh * dpr);
        canvas.style.width = vw + 'px';
        canvas.style.height = vh + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        initDots();
      }
      function initDots() {
        dots = [];
        const cols = Math.ceil(vw / GRID_SIZE) + 1;
        const rows = Math.ceil(vh / GRID_SIZE) + 1;
        for (let i = 0; i < cols; i++) {
          for (let j = 0; j < rows; j++) {
            const baseX = i * GRID_SIZE;
            const baseY = j * GRID_SIZE;
            dots.push({
              baseX: baseX, baseY: baseY,
              x: baseX, y: baseY,
              vx: 0, vy: 0,
              baseRadius: 1.2,
            });
          }
        }
      }
      function updateDot(d) {
        if (mouse.inside) {
          const dx = d.x - mouse.x;
          const dy = d.y - mouse.y;
          const dist = Math.hypot(dx, dy);
          if (dist < interactionRadius && dist > 0.1) {
            const force = (interactionRadius - dist) / interactionRadius;
            d.vx += (dx / dist) * force * forceFactor;
            d.vy += (dy / dist) * force * forceFactor;
          }
        }
        const springK = 0.08, friction = 0.82;
        d.vx += (d.baseX - d.x) * springK;
        d.vy += (d.baseY - d.y) * springK;
        d.vx *= friction;
        d.vy *= friction;
        d.x += d.vx;
        d.y += d.vy;
      }
      function drawFrame() {
        if (!running || prefersReduced) return;
        ctx.clearRect(0, 0, vw, vh);

        for (let i = 0; i < dots.length; i++) {
          const d = dots[i];
          updateDot(d);
          const distHome = Math.hypot(d.x - d.baseX, d.y - d.baseY);
          const stretchRatio = Math.min(1, distHome / 20);
          const radius = d.baseRadius + stretchRatio * 2.0;
          const maxOpacity = 0.15;
          const stretchOpacity = 0.7;
          const alpha = Math.min(1.0, maxOpacity + stretchRatio * stretchOpacity);

          ctx.beginPath();
          ctx.arc(d.x, d.y, radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
          ctx.fill();
          
          if(stretchRatio > 0.05) {
            ctx.beginPath();
            ctx.moveTo(d.baseX, d.baseY);
            ctx.lineTo(d.x, d.y);
            ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${alpha * 0.4})`;
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        }

        ctx.globalCompositeOperation = 'destination-out';
        ctx.fillStyle = 'rgba(0,0,0,1)';
        ctx.beginPath();
        const CX = vw / 2;
        const CY = vh / 2;
        const SCALE = vw < 640 ? 0.6 : 1;
        const RW = 162 * SCALE; 
        ctx.rect(CX - RW/2, 0, RW, vh);
        ctx.rect(0, CY - RW/2, vw, RW);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-over';

        requestAnimationFrame(drawFrame);
      }
      resize();
      if (!prefersReduced) requestAnimationFrame(drawFrame);
      window.addEventListener('resize', () => {
        dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
        resize();
      }, { passive: true });
    }
  })();
</script>
