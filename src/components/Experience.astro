---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="px-6 py-8 lg:px-14 lg:py-10">
      <div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 items-start">
            <div class="lg:col-span-3">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Experience
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />

          </div>

          <div class="lg:col-span-9 border border-gray-200 rounded-xl overflow-hidden divide-y divide-gray-100">
            {siteConfig.experience.map((exp) => (
              <div class="bg-white px-4 py-4">
                {/* Header row */}
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-3 min-w-0 flex-1">
                    {exp.logo && (
                      <img
                        src={exp.logo}
                        alt={exp.company}
                        class="w-5 h-5 object-contain flex-shrink-0 rounded"
                      />
                    )}
                    <span class="font-medium text-gray-900 text-sm truncate">
                      {exp.company}
                    </span>
                    <span class="text-gray-300 flex-shrink-0 text-xs">·</span>
                    <span class="text-gray-500 text-sm truncate">
                      {exp.title}
                    </span>
                  </div>
                  <span class="text-xs text-gray-400 flex-shrink-0 ml-3">
                    {exp.dateRange}
                  </span>
                </div>

                {/* Bullets always visible */}
                <ul
                  class="space-y-2 pl-3 border-l-2"
                  style={`border-color: ${siteConfig.accentColor}50`}
                >
                  {exp.bullets.map((bullet) => (
                    <li class="text-xs sm:text-sm text-gray-600 leading-relaxed">
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}


