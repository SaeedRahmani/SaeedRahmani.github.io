---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="p-6 sm:p-8 md:p-10 lg:p-14">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Experience
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            <p class="text-xs text-gray-400 mt-3 italic">hover or tap to expand</p>
          </div>

          <div class="lg:col-span-8 border border-gray-200 rounded-xl overflow-hidden divide-y divide-gray-100">
            {siteConfig.experience.map((exp) => (
              <div class="exp-row bg-white">
                {/* Collapsed single-line header */}
                <div class="flex items-center justify-between px-4 py-3 select-none">
                  <div class="flex items-center gap-3 min-w-0 flex-1">
                    {exp.logo && (
                      <img
                        src={exp.logo}
                        alt={exp.company}
                        class="w-5 h-5 object-contain flex-shrink-0 rounded"
                      />
                    )}
                    <span class="font-medium text-gray-900 text-sm truncate">
                      {exp.company}
                    </span>
                    <span class="text-gray-300 flex-shrink-0 text-xs">·</span>
                    <span class="text-gray-500 text-sm truncate hidden sm:block">
                      {exp.title}
                    </span>
                  </div>
                  <div class="flex items-center gap-3 flex-shrink-0 ml-3">
                    <span class="text-xs text-gray-400 hidden md:block">
                      {exp.dateRange}
                    </span>
                    <svg
                      class="chevron w-3.5 h-3.5 text-gray-400 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </div>
                </div>

                {/* Expanded content */}
                <div class="exp-content px-4 pb-4 pt-1">
                  <div class="flex items-center gap-2 mb-3 sm:hidden">
                    <span class="text-xs text-gray-500 font-medium">{exp.title}</span>
                    <span class="text-gray-300 text-xs">·</span>
                    <span class="text-xs text-gray-400">{exp.dateRange}</span>
                  </div>
                  <ul
                    class="space-y-2 pl-3 border-l-2"
                    style={`border-color: ${siteConfig.accentColor}50`}
                  >
                    {exp.bullets.map((bullet) => (
                      <li class="text-xs sm:text-sm text-gray-600 leading-relaxed">
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .exp-row {
    max-height: 52px;
    overflow: hidden;
    transition: max-height 0.5s ease-in-out;
    cursor: pointer;
  }

  .exp-row:hover,
  .exp-row.is-open {
    max-height: 500px;
  }

  .chevron {
    transition: transform 0.3s ease;
  }

  .exp-row:hover .chevron,
  .exp-row.is-open .chevron {
    transform: rotate(180deg);
  }

  .exp-content {
    opacity: 0;
    transition: opacity 0.2s ease 0.15s;
    pointer-events: none;
  }

  .exp-row:hover .exp-content,
  .exp-row.is-open .exp-content {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  document.querySelectorAll(".exp-row").forEach((row) => {
    row.addEventListener("click", () => {
      row.classList.toggle("is-open");
    });
  });
</script>
