---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasPublications = siteConfig.publications && siteConfig.publications.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 block transition-all duration-300"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <nav class="relative mx-auto px-6 lg:px-14 py-3 w-full flex items-center justify-between">
    <a
      href="#"
      class="text-sm font-medium text-gray-700 whitespace-nowrap hover:text-black transition-colors duration-200 flex-shrink-0"
      style={`--accent-color: ${siteConfig.accentColor}`}
    >
      {siteConfig.name}
    </a>
    <ul id="nav-list" class="flex items-center gap-3 sm:gap-4 md:gap-8 justify-end overflow-x-auto flex-nowrap scrollbar-hide">
      <li>
        <a
          href="#about"
          class="text-gray-700 hover:text-black transition-colors text-[11px] sm:text-[11px] sm:text-xs md:text-sm font-medium whitespace-nowrap"
        >
          About
        </a>
      </li>
      <li>
        <a
          href="#news"
          class="text-gray-700 hover:text-black transition-colors text-[11px] sm:text-xs md:text-sm font-medium whitespace-nowrap"
        >
          News
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a
              href="#projects"
              class="text-gray-700 hover:text-black transition-colors text-[11px] sm:text-xs md:text-sm font-medium whitespace-nowrap"
            >
              Projects
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href="#experience"
              class="text-gray-700 hover:text-black transition-colors text-[11px] sm:text-xs md:text-sm font-medium whitespace-nowrap"
            >
              Experience
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href="#education"
              class="text-gray-700 hover:text-black transition-colors text-[11px] sm:text-xs md:text-sm font-medium whitespace-nowrap"
            >
              Education
            </a>
          </li>
        )
      }
      {
        hasPublications && (
          <li>
            <a
              href="#publications"
              class="text-gray-700 hover:text-black transition-colors text-[11px] sm:text-xs md:text-sm font-medium whitespace-nowrap"
            >
              Publications
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<script>
  // Frosted-glass header on scroll
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });

  // Sliding highlight pill for nav items
  (function () {
    const nav = document.querySelector<HTMLElement>('#header nav');
    const ul  = document.getElementById('nav-list');
    if (!nav || !ul || window.matchMedia('(hover: none)').matches) return;

    // Resolve accent color for the pill
    const header  = document.getElementById('header')!;
    const accent  = getComputedStyle(header).getPropertyValue('--accent-color').trim() || '#1d4ed8';
    const m       = accent.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
    const bg      = m
      ? `rgba(${parseInt(m[1],16)},${parseInt(m[2],16)},${parseInt(m[3],16)},0.12)`
      : 'rgba(29,78,216,0.12)';

    const hl = document.createElement('span');
    hl.setAttribute('aria-hidden', 'true');
    Object.assign(hl.style, {
      position: 'absolute',
      borderRadius: '8px',
      background: bg,
      transition: 'opacity 0.12s ease',
      opacity: '0',
      pointerEvents: 'none',
      zIndex: '0',
    });
    // Attach to nav so ul's overflow-x clipping doesn't affect it
    nav.appendChild(hl);

    const PAD_X = 8, PAD_Y = 4;
    let active = false;

    function move(el: HTMLElement) {
      const navRect = nav.getBoundingClientRect();
      const r = el.getBoundingClientRect();
      hl.style.left   = (r.left - navRect.left - PAD_X) + 'px';
      hl.style.top    = (r.top  - navRect.top  - PAD_Y) + 'px';
      hl.style.width  = (r.width  + PAD_X * 2) + 'px';
      hl.style.height = (r.height + PAD_Y * 2) + 'px';
      if (!active) {
        // Snap to first item instantly, then enable sliding
        hl.style.opacity = '1';
        requestAnimationFrame(() => {
          hl.style.transition = 'left 0.2s ease, top 0.2s ease, width 0.2s ease, height 0.2s ease, opacity 0.12s ease';
        });
        active = true;
      } else {
        hl.style.opacity = '1';
      }
    }

    ul.querySelectorAll<HTMLAnchorElement>('a').forEach(a => {
      a.style.position = 'relative';
      a.style.zIndex = '1';
      a.addEventListener('mouseenter', () => move(a));
    });

    ul.addEventListener('mouseleave', () => {
      hl.style.opacity = '0';
      hl.style.transition = 'opacity 0.12s ease';
      active = false;
    });
  })();
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
  /* hide scrollbar on mobile nav row */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
