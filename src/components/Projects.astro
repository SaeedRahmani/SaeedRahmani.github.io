---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="px-6 py-8 lg:px-14 lg:py-10">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 items-start">
          <div class="lg:col-span-3">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-9">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? { href: project.link, target: "_blank", rel: "noopener noreferrer" }
                  : {};

                return (
                  <Component
                    {...linkProps}
                    class="group relative flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
                  >
                    {/* Top accent bar */}
                    <div
                      class="h-1 w-full"
                      style={`background: linear-gradient(to right, ${siteConfig.accentColor}, ${siteConfig.accentColor}60)`}
                    />

                    <div class="flex flex-col flex-1 p-4 gap-3">
                      {/* Header row: emoji + index */}
                      <div class="flex items-start justify-between">
                        <span
                          class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
                          style={`background-color: ${siteConfig.accentColor}10`}
                        >
                          {project.emoji || "🔬"}
                        </span>
                        <span
                          class="text-[11px] font-bold tabular-nums"
                          style={`color: ${siteConfig.accentColor}70`}
                        >
                          {String(index + 1).padStart(2, "0")}
                        </span>
                      </div>

                      {/* Title */}
                      <h3 class="text-sm font-semibold text-gray-900 leading-snug group-hover:text-blue-700 transition-colors duration-150 line-clamp-2">
                        {project.name}
                      </h3>

                      {/* Description */}
                      <p class="text-xs text-gray-500 leading-relaxed line-clamp-3 flex-1">
                        {project.description}
                      </p>

                      {/* Skills */}
                      {project.skills && project.skills.length > 0 && (
                        <div class="flex flex-wrap gap-1 pt-1 border-t border-gray-50">
                          {project.skills.map((skill) => (
                            <span
                              class="px-2 py-0.5 text-[11px] font-medium rounded-full border"
                              style={`color: ${siteConfig.accentColor}; border-color: ${siteConfig.accentColor}30; background-color: ${siteConfig.accentColor}08`}
                            >
                              {skill}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </Component>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
