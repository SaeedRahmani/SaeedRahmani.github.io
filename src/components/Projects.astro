---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

const gradients: [string, string][] = [
  ["#3b82f6", "#6366f1"],
  ["#8b5cf6", "#ec4899"],
  ["#10b981", "#0d9488"],
  ["#f59e0b", "#ef4444"],
  ["#06b6d4", "#3b82f6"],
  ["#7c3aed", "#a855f7"],
];
---

{
  hasProjects && (
    <section id="projects" class="p-6 sm:p-8 md:p-10 lg:p-14">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};
                const [fromColor, toColor] = gradients[index % gradients.length];

                return (
                  <Component
                    {...linkProps}
                    class="group block rounded-xl border border-gray-200 overflow-hidden bg-white hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
                  >
                    {/* Thumbnail */}
                    {project.image ? (
                      <div class="h-36 overflow-hidden">
                        <img
                          src={project.image}
                          alt={project.name}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                      </div>
                    ) : (
                      <div
                        class="h-36 flex items-center justify-center"
                        style={`background: linear-gradient(135deg, ${fromColor}, ${toColor})`}
                      >
                        <span class="text-4xl">{project.emoji || "🔬"}</span>
                      </div>
                    )}

                    {/* Card body */}
                    <div class="p-3.5">
                      <h3 class="font-semibold text-gray-900 text-sm leading-snug mb-1.5 line-clamp-2">
                        {project.name}
                      </h3>
                      <p class="text-xs text-gray-500 leading-relaxed mb-3 line-clamp-3">
                        {project.description}
                      </p>
                      {project.skills && project.skills.length > 0 && (
                        <div class="flex flex-wrap gap-1">
                          {project.skills.map((skill) => (
                            <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs font-medium">
                              {skill}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </Component>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
