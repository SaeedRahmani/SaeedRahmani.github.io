---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="px-6 py-8 lg:px-14 lg:py-10">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 items-start">
          <div class="lg:col-span-3">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900">
              Education
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            <p class="text-xs text-gray-400 mt-3 italic">hover or tap to expand</p>
          </div>

          <div class="lg:col-span-9 border border-gray-200 rounded-xl overflow-hidden divide-y divide-gray-100">
            {siteConfig.education.map((edu) => (
              <div class="edu-row bg-white">
                <div class="flex items-center justify-between px-4 py-3 select-none">
                  <div class="flex items-center gap-3 min-w-0 flex-1">
                    <span class="font-medium text-gray-900 text-sm truncate">
                      {edu.school}
                    </span>
                    <span class="text-gray-300 flex-shrink-0 text-xs">·</span>
                    <span class="text-gray-500 text-sm truncate hidden sm:block">
                      {edu.degree}
                    </span>
                  </div>
                  <div class="flex items-center gap-3 flex-shrink-0 ml-3">
                    <span class="text-xs text-gray-400 hidden md:block">
                      {edu.dateRange}
                    </span>
                    <svg
                      class="edu-chevron w-3.5 h-3.5 text-gray-400 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </div>
                </div>

                <div class="edu-content px-4 pb-4 pt-1">
                  <div class="flex items-center gap-2 mb-3 sm:hidden">
                    <span class="text-xs text-gray-500 font-medium">{edu.degree}</span>
                    <span class="text-gray-300 text-xs">·</span>
                    <span class="text-xs text-gray-400">{edu.dateRange}</span>
                  </div>
                  <ul
                    class="space-y-1.5 pl-3 border-l-2"
                    style={`border-color: ${siteConfig.accentColor}50`}
                  >
                    {edu.achievements.map((achievement) => (
                      <li class="text-xs sm:text-sm text-gray-600 leading-relaxed">
                        {achievement}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .edu-row {
    max-height: 52px;
    overflow: hidden;
    transition: max-height 0.5s ease-in-out;
    cursor: pointer;
  }

  .edu-row:hover,
  .edu-row.is-open {
    max-height: 400px;
  }

  .edu-chevron {
    transition: transform 0.3s ease;
  }

  .edu-row:hover .edu-chevron,
  .edu-row.is-open .edu-chevron {
    transform: rotate(180deg);
  }

  .edu-content {
    opacity: 0;
    transition: opacity 0.2s ease 0.15s;
    pointer-events: none;
  }

  .edu-row:hover .edu-content,
  .edu-row.is-open .edu-content {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  document.querySelectorAll(".edu-row").forEach((row) => {
    row.addEventListener("click", () => {
      row.classList.toggle("is-open");
    });
  });
</script>
